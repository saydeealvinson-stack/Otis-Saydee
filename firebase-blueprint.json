{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "A food or drink item on the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the dish" },
        "price": { "type": "number", "description": "Price in USD" },
        "description": { "type": "string", "description": "Short description of the item" },
        "category": { "type": "string", "enum": ["Starters", "Main Dishes", "Drinks", "Desserts"] },
        "image": { "type": "string", "format": "uri", "description": "URL to the food image" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Collection of all menu items"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
